$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: "/usr/local/emhttp";
$pluginName = "unraid-docker-orchestrator";
$configDir  = "/boot/config/plugins/{$pluginName}";
$configFile = "{$configDir}/config.json";

$config = [];
if (file_exists($configFile)) {
  $raw    = @file_get_contents($configFile);
  $config = $raw ? (json_decode($raw, true) ?: []) : [];
}
// Normaliser settings/prefs — forcer les objets vides en stdClass pour json_encode → {}
if (!isset($config['settings']) || !is_array($config['settings'])) $config['settings'] = [];
if (!isset($config['prefs'])    || !is_array($config['prefs']))    $config['prefs']    = [];
$config['settings'] = array_merge(['services'=>[],'timing'=>[],'pauses'=>[]], $config['settings']);
// Forcer {} au lieu de [] pour les sous-tableaux vides (évite SyntaxError JS)
foreach (['services','timing','pauses'] as $k) {
  if (isset($config['settings'][$k]) && is_array($config['settings'][$k]) && empty($config['settings'][$k])) {
    $config['settings'][$k] = new stdClass();
  }
}
if (is_array($config['prefs']) && empty($config['prefs'])) {
  $config['prefs'] = new stdClass();
}

// ── Détection langue ────────────────────────────────────────────────────────
// Priorité : 1. cookie (choix manuel utilisateur)  2. locale Unraid  3. 'en'
$supported_langs = ['fr', 'en', 'de', 'es'];

$unraid_lang = 'en';
$dynamix_cfg = '/boot/config/plugins/dynamix/dynamix.cfg';
if (file_exists($dynamix_cfg)) {
  $cfg_raw = @parse_ini_file($dynamix_cfg);
  $locale  = $cfg_raw['locale'] ?? '';
  // locale="fr_FR" ou "fr_FR.UTF-8" → extraire les 2 premiers chars
  $locale_prefix = strtolower(substr($locale, 0, 2));
  if (in_array($locale_prefix, $supported_langs)) {
    $unraid_lang = $locale_prefix;
  }
}

$lang_cookie = $_COOKIE['lang'] ?? '';
$lang = in_array($lang_cookie, $supported_langs) ? $lang_cookie : $unraid_lang;

// ── Détection conflit démarrage automatique Unraid ──────────────────────────
// Unraid stocke l'autostart dans /var/lib/docker/unraid-autostart
// Fichier texte : un nom de conteneur par ligne
$autostartContainerCount = 0;
$autostartFile = '/var/lib/docker/unraid-autostart';
if (file_exists($autostartFile)) {
  $lines = array_filter(array_map('trim',
    file($autostartFile, FILE_IGNORE_NEW_LINES) ?: []
  ));
  $autostartContainerCount = count($lines);
}
// Conflit = au moins un conteneur avec autostart Unraid activé
$autostartConflict = ($autostartContainerCount > 0);
?>
