<!-- ═══ MODALE CONFLIT DÉMARRAGE AUTOMATIQUE UNRAID ═══════════════════════ -->
<div id="autostart-conflict-overlay" class="udo-modal-overlay" style="display:none">
  <div class="udo-modal-box">
    <div class="udo-modal-icon">⚠️</div>
    <h2 class="udo-modal-title" data-i18n="autostart_modal_title">Conflit détecté</h2>
    <p class="udo-modal-body" id="autostart-modal-body" data-i18n="autostart_modal_body">
      Le <strong>démarrage automatique Docker</strong> d'Unraid est activé simultanément avec les scripts UDO.<br><br>
      Au boot, Unraid tentera de démarrer tous les conteneurs en vrac <em>en même temps</em> que UDO essaie de les démarrer dans l'ordre. Cela provoque des conflits imprévisibles.
    </p>
    <div class="udo-modal-warn" data-i18n="autostart_modal_warn">
      Il est fortement recommandé de désactiver le démarrage automatique Unraid et de laisser UDO gérer seul l'ordre de démarrage.
    </div>
    <div class="udo-modal-actions">
      <button class="udo-btn udo-btn-primary" onclick="disableUnraidAutostart()" data-i18n="autostart_modal_disable">
        Désactiver le démarrage automatique Unraid
      </button>
      <button class="udo-btn udo-btn-ghost" onclick="dismissAutostartConflict()" data-i18n="autostart_modal_ignore">
        Ignorer (non recommandé)
      </button>
    </div>
    <p id="autostart-ignore-warn" class="udo-modal-ignore-warn" style="display:none" data-i18n="autostart_modal_ignore_warn">
      ⚠️ UDO et le démarrage automatique Unraid seront actifs simultanément. Des conflits sont possibles au prochain démarrage.
    </p>
  </div>
</div>

<div id="settings-drawer" class="udo-log-drawer">
  <div class="udo-log-drawer-header">
    <div class="udo-log-drawer-title">
      <i class="fa fa-cog"></i>
      <span data-i18n="settings_title">Paramètres du plugin</span>
    </div>
    <button class="udo-log-drawer-close" onclick="closeSettingsDrawer()">
      <i class="fa fa-times"></i>
    </button>
  </div>

  <!-- Onglets -->
  <div class="udo-logs-tabs">
    <button class="udo-log-tab active" data-settings-tab="general" onclick="switchSettingsTab(this)">
      <span data-i18n="settings_tab_general">Général</span>
    </button>
    <button class="udo-log-tab" data-settings-tab="timeouts" onclick="switchSettingsTab(this)">
      <span data-i18n="settings_tab_timeouts">Timeouts containers</span>
    </button>
  </div>

  <!-- Onglet Général -->
  <div id="settings-tab-general" class="udo-settings-tab-content">
    <div class="udo-settings-grid">

      <div class="udo-settings-row">
        <label class="udo-settings-label" data-i18n="settings_global_timeout">Timeout global (s)</label>
        <input type="number" id="s-global-timeout" class="udo-settings-input" min="10" max="600" value="60">
      </div>

      <div class="udo-settings-row">
        <label class="udo-settings-label" data-i18n="settings_boot_delay">Délai boot (s)</label>
        <input type="number" id="s-boot-delay" class="udo-settings-input" min="0" max="300" value="60">
      </div>

      <div class="udo-settings-row">
        <label class="udo-settings-label" data-i18n="settings_default_pause">Pause entre groupes (s)</label>
        <input type="number" id="s-default-pause" class="udo-settings-input" min="0" max="60" value="5">
      </div>

      <div class="udo-settings-row">
        <label class="udo-settings-label" data-i18n="settings_abort_on_failure">Arrêter si timeout</label>
        <label class="udo-settings-toggle">
          <input type="checkbox" id="s-abort-on-failure">
          <span class="udo-settings-toggle-slider"></span>
        </label>
      </div>

      <div class="udo-settings-row">
        <label class="udo-settings-label" data-i18n="settings_log_refresh">Auto-refresh logs (s)</label>
        <input type="number" id="s-log-refresh" class="udo-settings-input" min="2" max="60" value="5">
      </div>

      <div class="udo-settings-row">
        <label class="udo-settings-label" data-i18n="settings_collapse_classify">Replier après classification</label>
        <label class="udo-settings-toggle">
          <input type="checkbox" id="s-collapse-classify" checked>
          <span class="udo-settings-toggle-slider"></span>
        </label>
      </div>

    </div>
  </div>

  <!-- Onglet Timeouts containers -->
  <div id="settings-tab-timeouts" class="udo-settings-tab-content" style="display:none">

    <div class="udo-settings-detect-bar">
      <button class="udo-btn udo-btn-secondary udo-btn-sm" onclick="detectTimeoutsFromLog()">
        <i class="fa fa-search"></i> <span data-i18n="settings_ct_detect">🔍 Détecter depuis logs</span>
      </button>
      <span id="settings-detect-status" class="udo-settings-detect-status"></span>
    </div>

    <div class="udo-settings-ct-header">
      <span data-i18n="settings_ct_name">Container</span>
      <span data-i18n="settings_ct_timeout">Timeout (s)</span>
      <span></span>
    </div>

    <div id="settings-ct-list" class="udo-settings-ct-list"></div>

    <button class="udo-btn udo-btn-secondary udo-btn-sm" style="margin-top:10px" onclick="addContainerTimeoutRow()">
      <i class="fa fa-plus"></i> <span data-i18n="settings_ct_add">+ Ajouter</span>
    </button>

  </div>

  <!-- Footer commun -->
  <div class="udo-settings-footer">
    <button class="udo-btn udo-btn-primary" onclick="saveSettings()">
      <i class="fa fa-save"></i> <span data-i18n="settings_save">Sauvegarder</span>
    </button>
    <span id="settings-save-status" class="udo-settings-save-status"></span>
  </div>
</div>

<!-- ═══ DRAWER VISIONNEUR DE LOGS ═══ -->
<div id="log-drawer-overlay" class="udo-log-overlay" onclick="closeLogsDrawer()"></div>
<div id="log-drawer" class="udo-log-drawer">
  <!-- Header du drawer -->
  <div class="udo-log-drawer-header">
    <div class="udo-log-drawer-title">
      <i class="fa fa-file-text-o"></i>
      <span data-i18n="log_viewer_title">Logs d'exécution des scripts</span>
    </div>
    <button class="udo-log-drawer-close" onclick="closeLogsDrawer()">
      <i class="fa fa-times"></i>
    </button>
  </div>

  <!-- Onglets de sélection -->
  <div class="udo-logs-tabs">
    <button class="udo-log-tab active" data-log="start"  onclick="switchLogTab(this)">
      <span data-i18n="log_select_start">🚀 Démarrage</span>
    </button>
    <button class="udo-log-tab" data-log="stop"   onclick="switchLogTab(this)">
      <span data-i18n="log_select_stop">🛑 Arrêt</span>
    </button>
    <button class="udo-log-tab" data-log="update" onclick="switchLogTab(this)">
      <span data-i18n="log_select_update">🔄 Mise à jour</span>
    </button>
  </div>

  <!-- Barre de statut + contrôles -->
  <div class="udo-logs-toolbar">
    <div class="udo-logs-status-bar">
      <span id="log-status-dot" class="udo-log-dot udo-log-dot-idle"></span>
      <span id="log-status-text" class="udo-log-status-text"></span>
      <span id="log-last-refresh" class="udo-log-last-refresh"></span>
    </div>
    <div class="udo-logs-controls">
      <label class="udo-logs-autorefresh">
        <input type="checkbox" id="log-auto-refresh" onchange="toggleLogAutoRefresh()">
        <span data-i18n="log_auto_refresh">Auto</span>
      </label>
      <button class="udo-btn udo-btn-secondary udo-btn-sm" onclick="refreshLog()">
        <i class="fa fa-refresh"></i>
      </button>
      <button class="udo-btn udo-btn-secondary udo-btn-sm" onclick="clearLog()">
        <i class="fa fa-trash"></i>
      </button>
    </div>
  </div>

  <!-- Zone log -->
  <div class="udo-log-viewer-wrap">
    <pre id="log-viewer-content" class="udo-log-viewer"></pre>
  </div>
</div>

<!-- ═══ MODALE GRAPHE DÉPENDANCES ═══════════════════════════════════════════ -->
