var UDO_CSRF_TOKEN       = '<?=_var($var,"csrf_token")?>';
var UDO_AUTOSTART_CONFLICT        = <?= $autostartConflict ? 'true' : 'false' ?>;
var UDO_AUTOSTART_CONTAINER_COUNT = <?= (int)$autostartContainerCount ?>;
</script>

