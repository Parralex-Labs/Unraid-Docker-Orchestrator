      <button class="dep-modal-close" id="dep-modal-close">✕</button>
    </div>
    <div class="dep-modal-body">
      <canvas id="dep-graph-modal"></canvas>
    </div>
    <div class="dep-modal-legend" id="dep-modal-legend"></div>
  </div>
</div>

